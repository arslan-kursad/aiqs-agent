# NOTE: gitignore does NOT support trailing inline comments — each pattern must
# be on its own line, comments on their own lines. (Learned the hard way.)

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- uv / venv ---
.venv/
# uv.lock IS committed (reproducibility — see CLAUDE.md). Do not ignore it.

# --- secrets (NEVER commit API keys) ---
.env
.env.*
!.env.example

# --- Datasets & model artifacts (large, regenerable) ---
# anomalib auto-downloads MVTec AD + imagenette here; we also stage prepared data
datasets/
# checkpoints / weights
models/
lightning_logs/
*.ckpt
*.pt
*.pth
*.onnx
*.bin

# --- Results ---
# results/metrics.csv and results/runs/<id>/{summary.md,image_scores.csv,config.yaml}
# ARE committed so configs can be compared over time. Heavy per-pixel dumps are not.
results/**/*.npz
results/**/anomaly_maps/
results/**/*.png
# ...but the Phase-1 risk-coverage / break-even plots ARE deliverables — keep them.
!results/**/risk_coverage*.png

# --- Local logs & scratch ---
*.log
scratch_*.py

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp

# Mock VLM smoke artifacts (wiring only, never evidence) — ALL mock_* files are walled off
results/runs/*/mock_*

# Phase-2B anomaly-map export — heavy per-pixel dumps (the crop instrument's input).
# Only the small manifest + the committed image_scores.csv reference these.
results/runs/*/anomaly_maps/

# --- Phase 3: LangGraph checkpoints (per-run sqlite state, not evidence/config) ---
*.sqlite
*.sqlite3
*.sqlite-shm
*.sqlite-wal
results/runs/*/serve_uploads/
